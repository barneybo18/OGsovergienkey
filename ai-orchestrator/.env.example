PRIVATE_KEY=your_wallet_private_key_here
# Galileo Testnet — Chain ID: 16602
# NOTE: This is the official 0G Galileo dev RPC. Do not use for production.
RPC_ENDPOINT=https://evmrpc-testnet.0g.ai/

STORAGE_NODE_URL=https://storage-testnet-rpc.0g.ai
# Galileo uses the turbo indexer. The old 'standard' indexer is Newton and is dead.
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

WALLET_ADDRESS=your_wallet_address_here

# ─── SP1 ZK Prover Mode ─────────────────────────────────────────────────────
# mock    → instant fake proof. No Succinct account needed. Use for demos/testing.
# network → Succinct cloud prover. Requires SP1_PRIVATE_KEY from succinct.xyz.
#           Without SP1_PRIVATE_KEY this will panic (exit 101).
# cpu     → Real local STARK proof. Needs 16GB+ RAM in WSL. Will SIGKILL on low RAM.
SP1_PROVER=mock

# Only required when SP1_PROVER=network.
# Register at https://succinct.xyz to get your key.
# SP1_PRIVATE_KEY=your_succinct_prover_key_here
