# 0G Galileo Testnet Configuration

# DEPRECATED for production: PRIVATE_KEY is no longer used by default. 
# Transactions are now signed by the user's browser wallet via wagmi.
# If you need to run CLI tests or bypass the browser, set the testing flag to true and provide a key:
USE_PRIVATE_KEY_FOR_TESTING=false
PRIVATE_KEY=0x... # Your wallet private key (must have Galileo tokens)

RPC_ENDPOINT=https://evmrpc-testnet.0g.ai/
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
