# ─── Wallet & Chain ────────────────────────────────────────────────────────
# Your wallet private key (used for contract deployment and agent transactions)
PRIVATE_KEY=0xyour_wallet_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Galileo Testnet — Chain ID: 16602
# NOTE: This is the official 0G Galileo dev RPC. Do not use for production.
RPC_ENDPOINT=https://evmrpc-testnet.0g.ai/

# ─── 0G Storage & DA ───────────────────────────────────────────────────────
STORAGE_NODE_URL=https://storage-testnet-rpc.0g.ai
# Galileo uses the turbo indexer.
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ─── ZK Prover (snarkjs) ───────────────────────────────────────────────────
# The ZK prover now runs locally using snarkjs + circom (Groth16).
# No external API keys are required for proving.
# Ensure you have run 'zk-engine/circuits/compile.sh' to generate artifacts.
