{
  "name": "sovereign-agent-zk-engine",
  "version": "0.1.0",
  "description": "ZK proving engine for Sovereign Agent Keys — circom + snarkjs (Groth16)",
  "main": "dist/prover.js",
  "scripts": {
    "build:circuit": "circom circuits/constitution.circom --r1cs --wasm --sym -o build",
    "setup": "node scripts/setup.js",
    "prove": "ts-node src/prover.ts",
    "verify": "ts-node src/verifier.ts",
    "export:verifier": "snarkjs zkey export solidityverifier build/constitution_final.zkey ../contracts/contracts/Groth16Verifier.sol",
    "export:vkey": "snarkjs zkey export verificationkey build/constitution_final.zkey build/verification_key.json",
    "build": "tsc",
    "start": "node dist/prover.js"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
